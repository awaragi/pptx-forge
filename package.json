{
  "name": "pptx-forge",
  "version": "1.8.1",
  "type": "module",
  "scripts": {
    "forge": "node bin/forge.js",
    "build": "node bin/forge.js",
    "generate": "node bin/forge.js",
    "backup": "node bin/backup.js",
    "create": "node bin/create.js",
    "build:browser": "node scripts/build-browser.js",
    "test": "node --test test/*.test.js",
    "pretest:e2e": "npm run build:browser",
    "test:e2e": "playwright test",
    "pretest:e2e:demo": "npm run build:browser",
    "test:e2e:demo": "SLOWMO_MS=${SLOWMO_MS:-1250} playwright test --headed --workers=1",
    "release:prepare": "node scripts/version.js",
    "release": "node scripts/publish.js"
  },
