    "url": "https://github.com/awaragi/pptx-forge.git"
  },
  "bugs": {
    "url": "https://github.com/awaragi/pptx-forge/issues"
  },
  "homepage": "https://github.com/awaragi/pptx-forge",
  "dependencies": {
    "archiver": "^8.0.0",
    "chart.js": "4.5.1",
    "jszip": "^3.10.1",
    "open": "^11.0.0",
    "pptxgenjs": "^3.12.0",
    "pptxviewjs": "1.1.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1"
